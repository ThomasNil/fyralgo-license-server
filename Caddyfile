he97.fyrvest.com, license.fyralgo.com {
    reverse_proxy api:8000
}

# fyralgo-ingest (separate repo/compose project, joins this box's shared `edge` network).
# api.fyralgo.com is a CNAME to he97.fyrvest.com -- see fyralgo-ingest/docs/DESIGN.md.
api.fyralgo.com {
    reverse_proxy fyralgo-ingest:8080
}

# truefill-web (separate repo/compose project, joins this box's shared `edge` network).
# Temporary hostname until truefill.io is registered -- add it to this same block when it is.
truefill.fyralgo.com {
    reverse_proxy truefill-web:3000
}

fyralgo.com, www.fyralgo.com {
    reverse_proxy web:3000
}

fyralgo.fyrvest.com {
    redir https://fyralgo.com{uri} permanent
}
# regtech-reporting mirror: EBA reference data (DPM database, taxonomy packages).
# Static files at C:\srv\frameworks on this box, volume-mounted read-only into this container
# (see docker-compose.yml). Served under /frameworks/ so reporting.fyrvest.com stays
# free for the reporting portal itself later. Immutable per release: a file is never
# replaced, a new version directory is added instead.
# Setup/consumers: regtech-reporting/docs/mirror.md
reporting.fyrvest.com {
    handle_path /frameworks/* {
        root * /srv/mirror
        file_server browse
        header Cache-Control "public, max-age=31536000, immutable"
    }
}
